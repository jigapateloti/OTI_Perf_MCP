# Example environment file for LRE chat-driven automation
# Copy this to .env and fill in your own values.

# Base URL for your LoadRunner Enterprise server
LRE_BASE_URL=https://your-lre-server.example.com

# LRE domain and project to target
LRE_DOMAIN=your-domain
LRE_PROJECT=your-project

# Tenant ID for authentication
TENANT_ID=your-tenant-id

# Credentials used for LRE authentication
LRE_USERNAME=your-username
LRE_PASSWORD=your-password
